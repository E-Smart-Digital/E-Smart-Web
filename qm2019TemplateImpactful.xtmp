			<value xml:lang="en-US">Next &#xf0a9;</value>
		</entry>
    <entry id="NEXT_QUESTION_TOOLTIP_BUTTON_TEXT" type="text" translate="yes" category="delivery">
      <description xml:lang="en-US"><![CDATA[Text for next question button]]></description>
      <value xml:lang="en-US">Next &#xf0a9;</value>
    </entry>
		<entry id="PREVIOUS_QUESTION_BUTTON_TEXT" type="text" translate="yes" category="delivery">
