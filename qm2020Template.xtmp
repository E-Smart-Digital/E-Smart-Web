<?xml version="1.0" encoding="UTF-8"?>
<xTemplate>
	<metadata>
		<version major="1" minor="0"/>
		<description xml:lang="en-US">Updated Questionmark Default template</description>
		<author>Shaun Wilson</author>
		<createdDate>019-05-25T10:37</createdDate>
		<comments>
			<comment author="Shaun Wilson" date="2019-05-25T10:37" xml:lang="en-US">Updated Questionmark Default template</comment>
		</comments>
	</metadata>
	<devices>
		<alternate>
			<class id="mobile">qxqon.xtmp</class>
		</alternate>
	</devices>
	<settings>
		<entry id="HOOK_SCRIPT" type="text" category="default">
			<value>
				<![CDATA[
					<script type="text/javascript">
						$(document).ready(function() {
						    function ContrastImageChange() {
						        var qmContrastDiv = document.getElementById("qmContrastChange");
						        var qmFontDiv = document.getElementById("qmFontChange");
						        var qmHelpDiv = document.getElementsByClassName("qm_HELP");
						        var isHighContrast = $("#qm_QUESTION").hasClass("HIGH_CONTRAST");

						        if (qmContrastDiv && qmFontDiv && qmHelpDiv) {
						            ToggleContrastImage(isHighContrast, qmContrastDiv.getElementsByTagName('img')[0], "contrast-nb.png", "contrastyellow-nb.png");
						            ToggleContrastImage(isHighContrast, qmFontDiv.getElementsByTagName('img')[0], "font-nb.png", "fontyellow-nb.png");
						            ToggleContrastImage(isHighContrast, qmHelpDiv[0].getElementsByTagName('img')[0], "help-nb.png", "helpyellow-nb.png");
						        }

						        var imgGraphicInputs = document.getElementsByClassName("qm_Graphic_Inputs");
						        ToggleInputGraphicsContrast(isHighContrast, imgGraphicInputs);
						    }

						    function ToggleContrastImage(isHighContrast, imgElement, defaultImage, contrastImage) {
						        if (imgElement != null) {
						            var filename = imgElement.src.replace(/^.*[\\\/]/, '');

						            if (isHighContrast) {
						                imgElement.src = imgElement.src.replace(filename, contrastImage);
						            } else {
						                imgElement.src = imgElement.src.replace(filename, defaultImage);
						            }
						        }
						    }

						    function ToggleInputGraphicsContrast(isHighContrast, imgGraphicInputs) {
						        for (var i = 0; i < imgGraphicInputs.length; i++) {
						            if (imgGraphicInputs[i].src) {
						                if (imgGraphicInputs[i].src.indexOf("radio-unchecked") > -1) {
						                    ToggleContrastImage(isHighContrast, imgGraphicInputs[i], "radio-unchecked-nb.png", "radio-unchecked-yellow-nb.png");
						                    radioOffGraphic = imgGraphicInputs[i].src;
						                } else if (imgGraphicInputs[i].src.indexOf("checkbox-unchecked") > -1) {
						                    ToggleContrastImage(isHighContrast, imgGraphicInputs[i], "checkbox-unchecked-nb.png", "checkbox-unchecked-yellow-nb.png");
						                    checkboxOffGraphic = imgGraphicInputs[i].src;
						                }
						            }
						        }
						    }

// Elements removed from JS
							    $("#qmFontChange, #qmContrastChange, .qm_HELP, #qm_UNFLAG_IMAGE, #qm_FLAG_IMAGE").hide();
						    $("#qmContrastChange").click(function() {
						        ContrastImageChange();
						    });

							if (isNavigationModeLinear === true && autoAdvanceTime > 0) {
								var timerInterval = setInterval(AdjustForAutoAdvanceTimer, 300);
								setTimeout(function() { clearInterval(timerInterval); }, 3000);
							}
						});

						WebFontConfig = {
						    google: {
						        families: ['Droid+Sans:400,700:latin']
						    }
						};

						$('body').ready(function() {
						    $('input[type=radio]').click(function() {
						        DoRadioClick(this);
						    });
						    $('input[type=checkbox]').click(function() {
						        $(this).parent().find('img:first').click();
						    });
						    $('input[type=checkbox]').click(function() {
						        DoCheckClick(this);
						    });
						});

						function AdjustForAutoAdvanceTimer() {
							if (isNavigationModeLinear !== true || autoAdvanceTime <= 0)
								return;

							// For Auto-Advance Timer
							var timerDimension = 150;
							var alignment = 0.875;

							var top = ($("#qm_DOCUMENT").height()/2) - (timerDimension/2);
							var alignValue = ($("#qm_DOCUMENT").width() * alignment) - timerDimension/2;
							var alignDirection = "left";

							// Footer Alignment

							if ($("html").attr("dir") === "rtl") {
								alignDirection = "right";
								$(".qm_SAYG_BUTTON").css("left", alignValue + "px");
							} else {
								$(".qm_SAYG_BUTTON").css("right", alignValue + "px");
							}

							$(".qm_QXQBUTTON, .qm_BUTTON").css("width", timerDimension + "px");

							var submitButtonDiv = $(".qm_FOOTER_BUTTON");
							submitButtonDiv.css("float", "none");
							submitButtonDiv.css("position", "absolute");
							submitButtonDiv.css(alignDirection, alignValue + "px");

							if (alignDirection === "right")
								submitButtonDiv.css("padding-right", 0);

							submitButtonDiv.show();

							// Content Alignment

							$(".qm_QA_CONTENT").width("75%");

							var autoAdvanceQuestionTimer = $("#autoAdvanceQuestionTimer");
							autoAdvanceQuestionTimer.css(alignDirection, alignValue + "px");
							autoAdvanceQuestionTimer.css("top", top + "px");

							$("#autoAdvanceQuestionBaseTimer").width(timerDimension + "px");
							$("#autoAdvanceQuestionBaseTimer").height(timerDimension + "px");
							var baseTimerLabel = $("#base-timer-label");
							baseTimerLabel.width(timerDimension + "px");
							baseTimerLabel.height(timerDimension + "px");
							baseTimerLabel.css("font-size", (timerDimension/5) + "px");

							// IE specific fixes
							if (navigator.appName === 'Microsoft Internet Explorer' || (navigator.userAgent.match(/Trident/))) {
								if (alignDirection === "right") {
									autoAdvanceQuestionTimer.css(alignDirection, (alignValue + 100 + timerDimension/4) + "px");
								}
							}
						}

						window.addEventListener("resize", AdjustForAutoAdvanceTimer);
					</script>
					
					]]>
			</value>
		</entry>
<entry id="HEADER_GRAPHIC" type="image" category="default">
				<value>xtmpgfx/Questionmark/logo.png</value>
				<description xml:lang="en">Graphic for page header</description>
			</entry>
		<entry id="FAVICON_GRAPHIC" type="image" category="default">
			<value>/static/qm_logo_bg_no_default.png?v=2</value>
			<description xml:lang="en">Graphic for favicon</description>
		</entry>
		<entry id="USE_QXQ" type="boolean" category="delivery">
			<value>1</value>
			<description xml:lang="en-US">Use question by question delivery</description>
		</entry>
		<entry id="STYLE" type="text" category="default">
			<value>
				html {background: #fff}
				/* Font */
				body, td, th, input, select, textarea, .qm_QUESTION_INTRO, .qm_QUESTION, .qm_HTML_CONTENT, .qm_INTRO, #qm_ASSESSMENT_HEADER .qm_TITLE, .qm_NUMBER, .qm_QXQBUTTON, .qm_QXQNAVBUTTON, #qm_Nav.qm_BUTTON, #qm_SUB.qm_BUTTON, #qm_QUIT.qm_BUTTON, #qm_CONT.qm_BUTTON, #qm_END.qm_BUTTON, .navst_link, .qm_QXQ_NAV_BLOCK_TITLE, .nav_cell_unanswered_hightlight, .nav_cell_unanswered, .nav_cell_answered, .nav_cell_answered_hightlight, .qm_FEEDBACK_ITEM, .qm_QUESTION_FEEDBACK { color: #333; font-family: 'Open Sans', sans-serif; font-size: 18px; line-height: 1.42857; font-weight: 300;}
				.qm_QXQBUTTON, .qm_QXQNAVBUTTON, #qm_Nav.qm_BUTTON, #qm_SUB.qm_BUTTON, #qm_QUIT.qm_BUTTON, #qm_CONT.qm_BUTTON, #qm_END.qm_BUTTON { font-size: 16px;}
				body .ui-tooltip{font-size:10pt !important;}
				body.MEDIUM .ui-tooltip{font-size:11pt !important;}
				body.LARGE .ui-tooltip{font-size:12pt !important;}
				/* Header and Banner section */
				.qm_BANNER { background: #fff none repeat scroll 0 0; height: 76px; padding: 3px 0 !important;}
				.qm_WELCOME { border: medium none; color: #333; height: 37px !important; padding: 13px 0 4px !important; background-size: contain; background-color: #000;}
				.qm_PROGRESS_BAR_CONTAINER { float:right; border: 1px solid #fff; height: 9px; border-radius: 5px;}
				.qm_PROGRESS_BAR { background: #000 none repeat scroll 0 0; height: 9px; border-radius: 5px;}
				#qm_Date { margin-left: 25px;}
				.qm_HELP { display: none !important; }
				.qm_HEADER_WELCOME_TEXT { float: left; width: auto; margin-top: 3px; padding-left: 5px; font-size: 16px; font-weight: 300;}
				#qm_Date { margin-left: 5%;}
				.qm_HELP { display: none !important; }
				.qm_PROGRESS_Text { float: right; padding-bottom: 5px; padding-top: 3px; padding-right: 5px; font-size: 11pt; font-weight: 300;color: #fff}
				.qm_TIMER { float: right; padding-bottom: 5px; padding-top: 3px; padding-right: 8px; padding-left: 8px; font-size: 16px; font-weight: 300;}
				.qm_Style_Icons { display: none !important; }
				.qm_HELP { display: none !important; }



				/* Document and question section */
				#qm_DOCUMENT { bottom: 70px !important; top: 137px !important; right: 130px;}
				#qm_QUESTION #qm_DOCUMENT { padding-left: 0;}
				#qm_ASSESSMENT_HEADER .qm_TITLE { border: medium none; color: inherit; font-family: 'Open Sans', sans-serif; font-size: 35px; font-weight: 100; line-height: 1.1; margin-bottom: 18px;}
				.qm_SEPARATOR { display: none;}
				.qm_QA_CONTENT { margin: 0 5%;}
				.qm_NUMBER { margin: 20px 5% 0;}
				.qm_EXPLANATION { margin: 20px 5% 0;}
				.qm_QUESTION_INTRO > #qm_ASSESSMENT_HEADER { margin: 0 5% 0; text-align: left; width: auto;}
				.qm_INTRO { margin: 0 5%;}
				.qm_QUESTION_INTRO { padding: 0; width: 100% !important;}
				.qm_QUESTION { padding: 0; width: 100% !important;}
				#qm_ASSESSMENT_HEADER { margin: 0 5% 0;}

				/* Footer section */
				#qm_FOOTER { background: #d8d8d8 none repeat scroll 0 0; height: 75px !important;}
				.qm_FOOTNOTE { display: none;}
				.qm_CONTROL { background: rgba(0, 0, 0, 0) none repeat scroll 0 0;}
				#qm_INTRO_btn { display: none !important;}
				.qm_QXQBUTTON, .qm_QXQNAVBUTTON, #qm_Nav.qm_BUTTON, #qm_SUB.qm_BUTTON, #qm_QUIT.qm_BUTTON, #qm_CONT.qm_BUTTON, #qm_END.qm_BUTTON { background: #000; border: 2px solid #000; color: #fff; font-size: 16px; height: 45px; margin-right: 10px; margin-top: 5px; border-radius: 5px; font-family: 'FontAwesome', 'Open Sans', sans-serif; padding: 10px 15px; width:115px;}
				input#qm_Nav.qm_BUTTON { background: #4E515D; border: 2px solid #4E515D;}

				/* Navigator section */
				.navst_link { font-size: 16px;}
				.qm_QXQ_NAV_BLOCK_TITLE { font-size: 16px;}
				.navst_box { background: #d8d8d8 none repeat scroll 0 0; border: 1px solid #333;}
				.qm_QXQ_NAV_BLOCKS { background: #d8d8d8 none repeat scroll 0 0; text-align: center; font-size: 16px;}
				.nav_cell_unanswered_hightlight { background: #4E515D none repeat scroll 0 0; border: 1px solid #fff; color: #fff; font-size: 16px;}
				.nav_cell_answered_hightlight { background: #3e6aae none repeat scroll 0 0; border: 1px solid #fff; color: #fff; font-size: 16px;}
				.nav_cell_unanswered { background: #fff none repeat scroll 0 0; font-size: 16px;}
				.nav_cell_empty { background: #fff none repeat scroll 0 0; font-size: 16px;}
				.nav_cell_answered { background: #3e6aae none repeat scroll 0 0; color: #fff; font-size: 16px;}

				/* Feedback section */
				.qm_FEEDBACK_ITEM { background-color: #eaeaea;}
				.qm_QUESTION_FEEDBACK { background: #d8d8d8 none repeat scroll 0 0; margin: 0 5%; padding: 7px; width: auto;}


				/* Medium Font CSS */
				body.MEDIUM .qm_BANNER { padding: 3px 0;}
				body.MEDIUM #qm_HEADER { height: 55px; top: 0;}
				body.MEDIUM .qm_HEADER_WELCOME_TEXT { margin-top: 3px; padding-left: 5px;}
				body.MEDIUM .qm_HELP { padding: 0 0 0 5px;}
				body.MEDIUM .qm_PROGRESS_BAR_CONTAINER { height: 9px; padding: 1px; top: 8px;}
				body.MEDIUM .qm_PROGRESS_BAR { height: 9px;}
				body.MEDIUM #qm_ASSESSMENT_HEADER .qm_TITLE { font-size: 40px;}
				body.MEDIUM #qm_ASSESSMENT_HEADER, #qm_BLOCK_SCORE { margin: 0 5% 0;}
				body.MEDIUM .qm_INTRO { font-size: 20px;}
				body.MEDIUM .qm_QUESTION_INTRO { font-size: 20px; padding: 0;}
				body.MEDIUM .qm_NUMBER { font-size: 20px; margin: 20px 5% 0;}
				body.MEDIUM .qm_HTML_CONTENT { font-size: 20px;}
				body.MEDIUM .qm_QUESTION { padding-top: 0;}
				body.MEDIUM #qm_FOOTER { bottom: 0; height: 75px !important;}
				body.MEDIUM .qm_QXQBUTTON, body.MEDIUM .qm_QXQNAVBUTTON, body.MEDIUM #qm_Nav.qm_BUTTON, body.MEDIUM #qm_SUB.qm_BUTTON, body.MEDIUM #qm_QUIT.qm_BUTTON, body.MEDIUM #qm_CONT.qm_BUTTON, body.MEDIUM #qm_END.qm_BUTTON { font-size: 17px;}
				body.MEDIUM .qm_CONTROL { height: 27px !important; padding: 6px 0 2px 7px !important;}
				body.MEDIUM .navst_link { font-size: 19px; padding-left: 6px;}
				body.MEDIUM .smatHead, body.MEDIUM .smatHeadHighlight, body.MEDIUM .smatRow, body.MEDIUM .smatRowHighlight { font-size: 20px; }

				/* Large Font CSS */
				body.LARGE .qm_BANNER { padding: 3px 0;}
				body.LARGE #qm_HEADER { height: 55px; top: 0;}
				body.LARGE .qm_HEADER_WELCOME_TEXT { margin-top: 3px; padding-left: 5px;}
				body.LARGE .qm_HELP { padding: 2px 0 0 5px;}
				body.LARGE .qm_PROGRESS_BAR_CONTAINER { height: 9px; padding: 1px; top: 8px; border: 1px solid #ccc;}
				body.LARGE .qm_PROGRESS_BAR { height: 9px;}
				body.LARGE #qm_ASSESSMENT_HEADER .qm_TITLE { font-size: 45px;}
				body.LARGE #qm_ASSESSMENT_HEADER, #qm_BLOCK_SCORE { margin: 0 5% 0;}
				body.LARGE .qm_INTRO { font-size: 22px;}
				body.LARGE .qm_QUESTION_INTRO { font-size: 22px; padding: 0;}
				body.LARGE .qm_NUMBER { font-size: 22px; margin: 20px 5% 0;}
				body.LARGE .qm_HTML_CONTENT { font-size: 22px;}
				body.LARGE .qm_QUESTION { padding-top: 0;}
				body.LARGE #qm_FOOTER { bottom: 0; height: 75px !important;}
				body.LARGE .qm_QXQBUTTON, body.LARGE .qm_QXQNAVBUTTON, body.LARGE #qm_Nav.qm_BUTTON, body.LARGE #qm_SUB.qm_BUTTON, body.LARGE #qm_QUIT.qm_BUTTON, body.LARGE #qm_CONT.qm_BUTTON, body.LARGE #qm_END.qm_BUTTON { font-size: 18px;}
				body.LARGE .qm_CONTROL { height: 27px !important; padding: 6px 0 2px 7px !important;}
				body.LARGE .navst_link { font-size: 20px; padding-left: 6px;}
				body.LARGE .smatHead, body.LARGE .smatHeadHighlight, body.LARGE .smatRow, body.LARGE .smatRowHighlight { font-size: 22px; }

				body.MEDIUM .qm_PROGRESS_Text { padding: 2px 5px 5px !important; font-size: 12pt;}
				body.LARGE .qm_PROGRESS_Text { padding: 1px 5px 5px !important; font-size: 13pt;}
				body.MEDIUM .qm_TIMER, body.LARGE .qm_TIMER { padding: 3px 8px 5px 8px;}
				body.MEDIUM .qm_TIMER {font-size: 18px;}
				body.LARGE .qm_TIMER {font-size: 20px;}
				.qm_HELP, body.MEDIUM .qm_HELP, body.LARGE .qm_HELP { float: right; width: 20px !important; padding: 0 0 0 5px !important; height: 25px !important;}

				@media (max-width: 1260px)
				{
				#qm_Date { margin-left: 25px;}
				.qm_HELP { display: none !important; }
				}

				/* Nav Styling */
				.nav_cell_unanswered_hightlight,.nav_cell_unanswered,.nav_cell_answered,.nav_cell_answered_hightlight{font-size:16px}
				.nav_palette_visible, body.MEDIUM .nav_palette_visible, body.LARGE .nav_palette_visible { bottom: 84px; margin: 0; right: 40px; z-index: 1; position: fixed; overflow: auto; outline: none; background: #405968; height: 200px; border-radius: 5px; border: 2px solid #000; padding: 5px;}
				.navst_box{background:transparent;border:medium none;margin-left:auto;margin-right:auto;width:640px}
				.qm_QXQ_NAV_BLOCKS{background:transparent}
				.navToolsGap{display:none}
				.qm_QXQ_NAV_BLOCK_TITLE{display:none}
				.nav_cell_unanswered_hightlight{background:transparent;border:2px solid #000;color:#000;font-size:14px}
				.nav_cell_answered_hightlight{ background: #4E515D; border: 2px solid #000; color: #fff; font-size: 14px;}
				.nav_cell_unanswered{background:#fff none repeat scroll 0 0;font-size:14px}
				.nav_cell_empty{background:#fff none repeat scroll 0 0;font-size:14px}
				.nav_cell_answered{background:#4E515D none repeat scroll 0 0;color:#fff;font-size:16px}.navst_box, body.MEDIUM .navst_box, body.LARGE .navst_box {background: transparent;border: medium none;margin-left: auto;margin-right: auto; width: auto; padding:0}
				body.MEDIUM .nav_cell_unanswered_hightlight, body.MEDIUM .nav_cell_unanswered, body.MEDIUM .nav_cell_answered, body.MEDIUM .nav_cell_answered_hightlight { font-size: 15px; width: 30px;}
				body.LARGE .nav_cell_unanswered_hightlight, body.LARGE .nav_cell_unanswered, body.LARGE .nav_cell_answered, body.LARGE .nav_cell_answered_hightlight { font-size: 16px; width: 30px;}
				#nav_title_tr td { text-align: center;}
				#nav_title_tr td img { height: 20px; width: auto;}
				.navst_box tbody { background: #405968;}
				span.navst_link { font-family: 'FontAwesome', 'Open Sans', Arial; color: #000; background: #405968; border-radius: 3px; padding: 5px 5px 6px 5px;}

				/* Highlight Flag */
				body.MEDIUM .qm_FOOTER_QxQ_BUTTONS#qm_FLAG_IMAGE img, body.MEDIUM .qm_FOOTER_QxQ_BUTTONS#qm_UNFLAG_IMAGE img, body.LARGE .qm_FOOTER_QxQ_BUTTONS#qm_FLAG_IMAGE img, body.LARGE .qm_FOOTER_QxQ_BUTTONS#qm_UNFLAG_IMAGE img { height: 20px; width: auto;}

				.qm_HEADER_WELCOME_TEXT { color: #fff;}
				.qm_BLOCK_TEXT_PROGRESS { display: none !important;}
				.qm_TIMER { color: #fff;}
				div#qm_FOOTER { background: #fff;}
				div#banner-text { position: absolute; top: 23px; right: 25px; color: #879baa; font-weight: bold; font-size: 14px;}
				div#footer-text { display: inline !important; position: fixed; width: auto; bottom: 0px; font-size: 11px; right: 25px;}
				div#footer1 { display: inline !important; color: #ed3830; font-size: 13px;}
				div#footer2 { display: inline !important; font-size: 13px;}
				.qm_Style_Icons img { height: 27px; width: auto;}
				.qm_HELP img { height: 27px; width: auto;}

				/* below th css fixes the issue with content being misaligned on some screen sizes */
				th { text-align: left !important;}
				legend {max-width:100%;}

				div#qm_SAYG_ICON,div#qm_SAYG_WORKING_ICON { margin-top: 14px; position: absolute; right: 275px;}
				.assessListTable td { white-space: normal;}
				td.nav_cell_empty { display: none;}
				tr.GridHeader { background: #405968;}
				.qm_QUESTION_FEEDBACK { background: #fff;}


#qm_FLAG_IMAGE, #qm_UNFLAG_IMAGE { display: none !important; }
				#Highlight_Text, #Remove_Highlight_Text { font-size: 12px; float: right; margin-top: 6px; font-weight: bold;}

				/* Questionmark Specific */
				.qm_BANNER { background: #000;}
				div#qm_Loger, div#qm_Date { color: #fff;}
				.qm_WELCOME { background: linear-gradient(to right, #1c96fc, #166efd)}
				.qm_QXQBUTTON, .qm_QXQNAVBUTTON, #qm_Nav.qm_BUTTON, #qm_SUB.qm_BUTTON, #qm_QUIT.qm_BUTTON, #qm_CONT.qm_BUTTON, #qm_END.qm_BUTTON {width:auto}
				#qm_DOCUMENT {right: 0}

				/* Questionmark NEW High Contrast */
				body.HIGH_CONTRAST th {color: #fff !important;}
				body.HIGH_CONTRAST, body.HIGH_CONTRAST .qm_WELCOME, body.HIGH_CONTRAST .qm_QUESTION .qm_QA_CONTENT, body.HIGH_CONTRAST .qm_HEADER_WELCOME_TEXT, body.HIGH_CONTRAST #qm_HTML_CONTENT,
				body.HIGH_CONTRAST #qm_QUESTION #qm_FOOTER, body.HIGH_CONTRAST .qm_FOOTNOTE, body.HIGH_CONTRAST #qm_DOCUMENT, body.HIGH_CONTRAST .qm_FINAL_SCORE, body.HIGH_CONTRAST #qm_ASSESSMENT_HEADER .qm_TITLE,
				body.HIGH_CONTRAST .qm_INTRO, body.HIGH_CONTRAST .qm_QUESTION, body.HIGH_CONTRAST .qm_ANSWERED, body.HIGH_CONTRAST .qm_NOT_ANSWERED, body.HIGH_CONTRAST .qm_HTML_CONTENT,
				body.HIGH_CONTRAST .qm_ASSESSMENT_OUTCOME, body.HIGH_CONTRAST .assessListTable td, body.HIGH_CONTRAST .assessListTable th, body.HIGH_CONTRAST .qm_TEXT_tm, body.HIGH_CONTRAST INPUT[type=text],
				body.HIGH_CONTRAST textarea, body.HIGH_CONTRAST .qm_TEXT_essay, body.HIGH_CONTRAST .ui-widget-content, body.HIGH_CONTRAST .ui-dialog-content, body.HIGH_CONTRAST .qm_SELECT_sab,
				body.HIGH_CONTRAST .qm_SELECT_match, body.HIGH_CONTRAST .qm_SELECT_rank, body.HIGH_CONTRAST .qm_SELECT_sel, body.HIGH_CONTRAST .GridHeader td, body.HIGH_CONTRAST .Gridheader th,
				body.HIGH_CONTRAST input.button, body.HIGH_CONTRAST .qm_QXQBUTTON, body.HIGH_CONTRAST .qm_QXQNAVBUTTON, body.HIGH_CONTRAST .qm_FOOTER_BUTTON, body.HIGH_CONTRAST .qm_BUTTON,
				body.HIGH_CONTRAST .qm_BUTTON_upload, body.HIGH_CONTRAST #qm_FOOTER .qm_CONTROL, body.HIGH_CONTRAST .navst_box, body.HIGH_CONTRAST #nav_title_tr td, body.HIGH_CONTRAST .navst_link,
				body.HIGH_CONTRAST .qm_QXQ_NAV_BLOCK_TITLE, body.HIGH_CONTRAST .qm_NUMBER, body.HIGH_CONTRAST #qm_NEXT_btn, body.HIGH_CONTRAST #qm_NEXT, body.HIGH_CONTRAST #qm_Nav, body.HIGH_CONTRAST #qm_NAV_btn,
