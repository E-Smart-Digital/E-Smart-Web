				div#qm_DOCUMENT, body.MEDIUM #qm_DOCUMENT, body.LARGE #qm_DOCUMENT { right: 0; left: 0;}

				/* New Branding */
				.qm_QXQBUTTON, .qm_QXQNAVBUTTON, #qm_Nav.qm_BUTTON, #qm_SUB.qm_BUTTON, #qm_QUIT.qm_BUTTON, #qm_CONT.qm_BUTTON, #qm_END.qm_BUTTON { background: #143345; border: 2px solid #143345;}
				input#qm_Nav.qm_BUTTON { background: #405968; border: 2px solid #405968;}

				.qm_PROGRESS_BAR { background: #ee348c none repeat scroll 0 0;}
				span.navst_link { color: #fff;}
				img.qm_Graphic_Inputs { height: 27px; width: auto;}
				.nav_cell_unanswered_hightlight { background: #54C4C2; background-repeat: no-repeat;}
				.nav_cell_answered_hightlight { background: linear-gradient(to right bottom, #5fc0c2 0%,#5fc0c2 49.9%,#000000 50%,#000000 52%,#5fc0c2 52.1%,#5fc0c2 100%); background-repeat: no-repeat; border: none;}
				.nav_cell_answered { background: linear-gradient(to right bottom, #5fc0c2 0%,#5fc0c2 49.9%,#000000 50%,#000000 52%,#5fc0c2 52.1%,#5fc0c2 100%); background-repeat: no-repeat; border: none;}
				.assessListTable .GridHeader td { color: #fff; font-weight: lighter;}

				.qm_BANNER { background: url(xtmpgfx/Questionmark/corner-triangle.png) no-repeat, #1F3346;}
				.qm_WELCOME:before { content: ''; background: #13222d; height: 54px; width: 100px; position: absolute; transform: skewX(-50deg); top: 83px; left: -36px;}
				.qm_WELCOME { border-top: 1px solid #13222d; background: #1f3346;}
				.qm_BANNER img { height: clamp(48px, 24%, 70px)!important; margin: 1px 15px; width: auto; border-radius: 7px; padding-top: 16px;}
				input#qm_SUB.qm_BUTTON, input#qm_END.qm_BUTTON { background: #5FC0C2; border: 0.125rem solid rgba(0, 0, 0, 0.1); font-family: 'FontAwesome', 'Open Sans', sans-serif; color: #000; border-radius: 0; box-shadow: 0 0.25rem 0.25rem rgba(0, 0, 0, 0.26);}
				.qm_QXQBUTTON, .qm_QXQNAVBUTTON, #qm_Nav.qm_BUTTON, #qm_SUB.qm_BUTTON, #qm_QUIT.qm_BUTTON, #qm_CONT.qm_BUTTON, #qm_END.qm_BUTTON { background: #143345; border: 0.125rem solid rgba(0, 0, 0, 0.1); border-radius: 0; box-shadow: 0 0.25rem 0.25rem rgba(0, 0, 0, 0.26);}
				.qm_QXQBUTTON:hover, .qm_QXQNAVBUTTON:hover, #qm_Nav.qm_BUTTON:hover, #qm_QUIT.qm_BUTTON:hover, #qm_CONT.qm_BUTTON:hover, input#qm_NEXT:hover, input#qm_PREV:hover { background: #13222d; color: #fff;}
				input#qm_Nav.qm_BUTTON { background: #405968; border: 2px solid #405968; box-shadow: 0 0.25rem 0.25rem rgba(0, 0, 0, 0.26); border: 0.125rem solid rgba(0, 0, 0, 0.1);}
				#qm_Nav.qm_BUTTON:hover { background: #143345;}
				#qm_SUB.qm_BUTTON:hover, #qm_END.qm_BUTTON:hover { background: #19838C;}
				.nav_palette_visible, body.MEDIUM .nav_palette_visible, body.LARGE .nav_palette_visible { border-radius: 0; box-shadow: 0 0.25rem 0.25rem rgba(0, 0, 0, 0.26); border: 0.125rem solid rgba(0, 0, 0, 0.1);}
				.nav_cell_answered {background: linear-gradient(to right bottom, #19838C 0%,#19838C 49.9%,#000000 50%,#000000 52%,#19838C 52.1%,#19838C 100%);background-repeat: no-repeat;}

				.nav_cell_unanswered, .nav_cell_unanswered_hightlight, .nav_cell_unanswered, .nav_cell_answered, .nav_cell_answered_hightlight {border: 0.125rem ;}
				tr.GridHeader { background: #1f3346;}

				/* New Text Colour */
				body, td, th, input, select, textarea, .qm_QUESTION_INTRO, .qm_QUESTION, .qm_HTML_CONTENT, .qm_INTRO, #qm_ASSESSMENT_HEADER .qm_TITLE, .qm_NUMBER, .qm_QXQBUTTON, .qm_QXQNAVBUTTON, #qm_Nav.qm_BUTTON, #qm_SUB.qm_BUTTON, #qm_QUIT.qm_BUTTON, #qm_CONT.qm_BUTTON, #qm_END.qm_BUTTON, .navst_link, .qm_QXQ_NAV_BLOCK_TITLE, .nav_cell_unanswered_hightlight, .nav_cell_unanswered, .nav_cell_answered, .nav_cell_answered_hightlight, .qm_FEEDBACK_ITEM, .qm_QUESTION_FEEDBACK { color: #1f3346;}
				.qm_QXQBUTTON, .qm_QXQNAVBUTTON, #qm_Nav.qm_BUTTON, #qm_SUB.qm_BUTTON, #qm_QUIT.qm_BUTTON, #qm_CONT.qm_BUTTON, #qm_END.qm_BUTTON { color: #fff;}
				.qm_ANSWERED, .qm_NOT_ANSWERED { background: #1f3346; color: #fff;}
				p.qm_SECTION_HEADER { font-size: 18px; font-weight: normal;}
				#qm_ASSESSMENT_HEADER .qm_TITLE { color: #AA1357;}
				.assessListTable td a { color: #e72b80;}

				/* Question Time */
				body.HIGH_CONTRAST.base-timer__label {color: #fff; }
				body.HIGH_CONTRAST #base-timer-path-remaining { color: #EB9ECA !important;}

				/* Question padding not consistent in QxQ */
				p { margin-top: 0;}
				.qm_QUESTION_fib { padding-top: 0;}
				.qm_QUESTION_sab { padding-top: 0;}

				html[dir="rtl"] .smatTable {border-left: 1px solid lightgrey; margin-top: 5px; padding:0px; border-right: none }
				html[dir="rtl"] .smatHead { font-family: verdana, tahoma; text-align:center; border-top: 1px solid lightgrey; border-right: 1px solid lightgrey; border-bottom: 1px solid lightgrey; font-weight:normal; border-left: none }
				html[dir="rtl"] .smatRow { font-family: verdana, tahoma; border-bottom: 1px solid lightgrey; border-right: 1px solid lightgrey; border-left: none }
				html[dir="rtl"] .smatOption { border-bottom: 1px solid lightgrey; border-right: 1px solid lightgrey; text-align: center; cursor: pointer; border-left: none; }
				html[dir="rtl"] .qm_FOOTER_QxQ_BUTTONS {float:right;}
				html[dir="rtl"] .qm_FOOTER_QxQ_NAVIGATOR_BUTTON {float:right;}
				html[dir="rtl"] .qm_FOOTER_BUTTON {float:left;}
				html[dir="rtl"] .qm_HELP {margin-left:5%;margin-right:0%}
				html[dir="rtl"] #qm_ASSESSMENT_HEADER {float:right;}.
				html[dir="rtl"] .qm_TITLE {float:right;}
				html[dir="rtl"] .qm_INTRO {float:right;width:100%}
				html[dir="rtl"] .qm_QUESTION_INTRO {width:92% !important}
				html[dir="rtl"] div#qm_Loger {left:5%;right:auto;top:45px}
				html[dir="rtl"] div#qm_Date {left:5%;right:auto;top:20px}
				html[dir="rtl"] #qm_Date {margin-right:5%;margin-left:0%;}
				html[dir="rtl"] .qm_BANNER {-webkit-transform: scaleX(-1); transform: scaleX(-1);transform: scaleX(-1);-ms-transform: scaleX(-1);}
				html[dir="rtl"] .qm_BANNER img {float:left; padding-right:0px; padding-left:20px; -webkit-transform: scaleX(-1); transform: scaleX(-1);-ms-transform: scaleX(-1);}
				html[dir="rtl"] .qm_TIMER {float:left;}
				html[dir="rtl"] .qm_PROGRESS_BAR_CONTAINER {float:left;}
				html[dir="rtl"] .qm_WELCOME:before {left:0px;right:0px;transform: skewX(50deg)}
				html[dir='rtl'] #qm_QUESTION #qm_DOCUMENT {padding-right:0px}
				html[dir='rtl'] .qm_HELP, html[dir='rtl'] body.MEDIUM .qm_HELP, html[dir='rtl'] body.LARGE .qm_HELP {float:left;}
				html[dir='rtl'] .qm_QUESTION_hot{float:right;width:100%;}
				html[dir='rtl'] .qm_ANSWERED,html[dir='rtl'] .qm_NOT_ANSWERED { float:right;width:100%;}
				html[dir='rtl'] .qm_PROGRESS_Text { float: left; padding-bottom: 5px; padding-top: 1px; padding-left: 5px; font-weight: 300;color: #fff}
				.qm_RADIO_hidden, .qm_CHECK_hidden {width:auto;margin:-3}

				/* Bug Fixes */
				.qm_CHOICE_num, .qm_CHOICE_sab, .qm_CHOICE_fib, .qm_COMMENT, .qm_BUTTON_upload { margin: 5px; }
				.qm_SAYG_BUTTON img {height: 24px !important;width: 24px  !important;}
				body.MEDIUM .qm_SAYG_BUTTON img, body.LARGE .qm_SAYG_BUTTON img {height: 24px !important;width: 24px  !important;}
				body.HIGH_CONTRAST #qm_SAYG_ICON img { content : url(xtmpgfx/Questionmark/qm2020/qmSAYG-hc.svg)}
				body.HIGH_CONTRAST #qm_SAYG_WORKING_ICON img { content: url(xtmpgfx/Questionmark/qm2020/load-hc.svg)}

			</value>
		</entry>
		<entry id="DISABLE_SHORTCUT_KEYS" type="integer" category="default">
			<value>1</value>
			<description xml:lang="en-US">Disables the use of Alt key and partially disables Ctrl and 'Backspace' key allowing them to be used to do text editing like copy, paste, delete etc.</description>
		</entry>
